# Copy to .env (git-ignored) and edit. Placeholders only — NEVER commit real secrets.

# --- Read-only scanning needs NONE of the trading creds below ---
LOG_LEVEL=INFO
MIN_PROFIT_BPS=30
MIN_NOTIONAL_USDC=50
EXCLUDE_AT_RISK_RESOLUTION=true
SCAN_INTERVAL_SECONDS=5
NOTIFIER=none            # none | webhook | discord  (ntfy/telegram not yet built → fall back to none)
NOTIFIER_URL=            # required for webhook/discord. Discord: channel → Integrations → Webhooks → Copy URL
# To alert a Discord channel on every emitted opportunity:
#   NOTIFIER=discord
#   NOTIFIER_URL=https://discord.com/api/webhooks/<id>/<token>
SQLITE_PATH=polyarb.db

# --- WebSocket streaming (the DEFAULT read path; REST is the resync/backup) ---
# Books are kept in-memory from the market-channel websocket; a candidate detected off the cache
# is REST-confirmed before emit. Set STREAMING_ENABLED=false to fall back to the pure-REST poll.
STREAMING_ENABLED=true
WS_RESYNC_INTERVAL_S=60       # full-depth REST resync cadence (the backup/correction read)
WS_STALL_TIMEOUT_S=60        # force-reconnect a connected-but-silent feed after this many seconds
WS_FRESHNESS_S=90            # detect only off books refreshed within this window (>= resync + margin)
WS_MAX_BACKOFF_S=30          # cap on reconnect backoff
# WS_HEARTBEAT_PATH=         # set (with HEARTBEAT_PATH) to make the healthcheck stream-aware

# --- Optional Prometheus /metrics endpoint (off by default) ---
METRICS_ENABLED=false
METRICS_PORT=9090

# --- Execution module (leave disabled) ---
EXECUTION_ENABLED=false
MAX_TRADE_NOTIONAL_USDC=0
# POLYMARKET_PRIVATE_KEY=     # never commit a real value; set in env only when enabling execution
# POLYMARKET_FUNDER_ADDRESS=
